{
  "name": "resolve-api",
  "version": "1.0.0",
  "description": "Node.js + Express + MongoDB API",
  "main": "src/server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/server.ts\"",
    "typecheck": "tsc --noEmit",
    "migrate:article-authors": "tsx src/scripts/migrateArticleAuthors.ts",
    "migrate:billing-roles": "tsx src/scripts/migrateBillingRoles.ts",
    "migrate:categories": "tsx src/scripts/migrateCategories.ts",
    "migrate:regions": "tsx src/scripts/migrateRegions.ts",
    "migrate:ai-summary": "tsx src/scripts/migrateAiSummary.ts",
    "backfill:embeddings": "tsx src/scripts/backfillEmbeddings.ts",
    "seed:articles": "tsx src/scripts/seedArticles.ts",
    "create:vector-index": "tsx src/scripts/createVectorIndex.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@clerk/backend": "^3.4.14",
    "@clerk/express": "^2.1.22",
    "@google/genai": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "resend": "^6.12.4",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "nodemon": "^3.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
